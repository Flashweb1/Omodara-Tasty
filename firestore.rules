rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public creation of newsletter subscriptions, but restrict reading
    match /newsletter/{docId} {
      allow create: if true;
      allow read, update, delete: if false; 
    }
    
    // Allow public submission for inquiries
    match /inquiries/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Allow public creation for orders
    match /orders/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}